  m_Script: {fileID: 11500000, guid: 0af63463b56e7e145bed05d806710549, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::FrameManager
  frameText: {fileID: 0}
  playerText:
  - "I\u2026 don\u2019t want to forget\\nI don\u2019t want to forget about her. She
    is important. So important. Why can\u2019t I remember her name?   What were we
    doing? \\nWhy is this important again?  I remember\u2026. "
  avoidantText:
  - Her favorite restaurant. Spanish tapas. She likes it because of the time she
    spent studying abroad in Spain. You always resented her for leaving. She probably
    cheated on you. But it was worth it to be with her. She glowed when she was happy.
  joyfulText:
  - "Your favorite restaurant! Of course. You were on a date with her. She loves
    this restaurant too, that\u2019s why you picked it. Italian. Italian is classic.
    That\u2019s why you went with it. You love italian too. And you wanted to split
    a bottle of wine. "
  insecureText:
  - 'The sushi place. A common place for you two to be at. She liked it, you liked
    it well enough. A good enough place as any for a conversation. '
  currentTalkingState: 0
  index: 0
